---
layout: layouts/base.njk
title: Contact
description: Get in touch with SARA Sanctuary. General inquiries, adoption, volunteer coordination, and visits are all by email. Sanctuary address is 1050 Rawhide Rd, Seguin, TX.
permalink: /contact/
---

<header class="page-head photo-head" style="background-image: url('/images/barn.webp');">
  <div class="container">
    <span class="eyebrow">Contact</span>
    <h1>Get in touch.</h1>
    <p>We're a small team doing a lot of work. Email is the fastest way to reach us. For urgent animal welfare matters, please call.</p>
  </div>
</header>

<section>
  <div class="container">
    <div class="two-col">
      <div>
        <span class="eyebrow">Email</span>
        <h2>Who to contact for what.</h2>

        <div class="info-grid">
          <div class="info-box">
            <div class="k">General Inquiries</div>
            <div class="v"><a href="mailto:{{ site.emails.general }}">{{ site.emails.general }}</a></div>
          </div>
          <div class="info-box">
            <div class="k">Tracy (Founder &amp; Director)</div>
            <div class="v"><a href="mailto:{{ site.emails.tracy }}">{{ site.emails.tracy }}</a></div>
          </div>
          <div class="info-box">
            <div class="k">Adoption &amp; Foster</div>
            <div class="v"><a href="mailto:{{ site.emails.adoption }}">{{ site.emails.adoption }}</a></div>
          </div>
          <div class="info-box">
            <div class="k">Volunteer Coordinator</div>
            <div class="v"><a href="mailto:{{ site.emails.volunteer }}">{{ site.emails.volunteer }}</a></div>
          </div>
        </div>

        <div style="margin-top: 2rem;">
          <span class="eyebrow">Phone</span>
          <h3><a href="{{ site.phoneHref }}">{{ site.phone }}</a></h3>
          <p class="muted">We're a working sanctuary, so we may not answer immediately. Leave a voicemail and we'll call back.</p>
        </div>
      </div>

      <div>
        <span class="eyebrow">Location</span>
        <h2>Visits by appointment only.</h2>
        <div class="info-grid">
          <div class="info-box">
            <div class="k">Sanctuary Address</div>
            <div class="v">{{ site.address.line1 }}<br>{{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}</div>
          </div>
          <div class="info-box">
            <div class="k">Mailing Address</div>
            <div class="v">{{ site.address.mailing }}</div>
          </div>
        </div>

        <p class="muted" style="margin-top: 1rem;">We're 68 miles south of Austin and 42 miles east of San Antonio. The sanctuary is not open for unscheduled drop-ins.</p>

        <div style="margin-top: 1.5rem; border-radius: var(--rad); overflow: hidden; aspect-ratio: 16/10;">
          <iframe
            width="100%"
            height="100%"
            frameborder="0"
            style="border:0;"
            src="https://www.openstreetmap.org/export/embed.html?bbox=-97.9700%2C29.5200%2C-97.8700%2C29.6000&amp;layer=mapnik&amp;marker=29.5600%2C-97.9200"
            loading="lazy">
          </iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<section style="background: var(--cream-2);">
  <div class="container">
    <div class="prose">
      <span class="eyebrow">Stay Connected</span>
      <h2>Follow along on social.</h2>
      <p>Daily photos, videos of our residents, and behind-the-scenes sanctuary life.</p>

      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <a href="{{ site.links.facebook }}" target="_blank" rel="noopener" class="btn btn-ghost">Facebook</a>
        <a href="{{ site.links.instagram }}" target="_blank" rel="noopener" class="btn btn-ghost">Instagram</a>
        <a href="{{ site.links.youtube }}" target="_blank" rel="noopener" class="btn btn-ghost">YouTube</a>
        <a href="{{ site.links.tiktok }}" target="_blank" rel="noopener" class="btn btn-ghost">TikTok</a>
        <a href="{{ site.links.patreon }}" target="_blank" rel="noopener" class="btn btn-ghost">Patreon</a>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="prose">
      <span class="eyebrow">Send a Note</span>
      <h2>Or drop us a message here.</h2>
      <form netlify name="contact" method="POST" action="/thanks/" style="display: grid; gap: 1rem; max-width: 640px;">
        <input type="hidden" name="form-name" value="contact">
        <label>
          <span style="display: block; font-weight: 600; margin-bottom: 0.25rem;">Your name</span>
          <input type="text" name="name" required autocomplete="name">
        </label>
        <label>
          <span style="display: block; font-weight: 600; margin-bottom: 0.25rem;">Email</span>
          <input type="email" name="email" required autocomplete="email">
        </label>
        <label>
          <span style="display: block; font-weight: 600; margin-bottom: 0.25rem;">Subject</span>
          <input type="text" name="subject" autocomplete="off">
        </label>
        <label>
          <span style="display: block; font-weight: 600; margin-bottom: 0.25rem;">Message</span>
          <textarea name="message" rows="5" required></textarea>
        </label>
        <button type="submit" class="btn btn-primary" style="justify-self: start;">Send Message</button>
      </form>
    </div>
  </div>
</section>
